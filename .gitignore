# ── Manuscripts ──────────────────────────────────────────────────────────────
# Track the active draft and bibliography; exclude legacy artifacts
drafts/*_legacy*
drafts/*_Whitepaper*
# compiled PDFs are build outputs, not source
drafts/*.pdf
# LaTeX source and bibliography — track these
!drafts/*.tex
!drafts/*.bib

# ── Local noise ──────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
.Rhistory
*.swp
*.swo

# ── Python artifacts ──────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ── Large raw data (not reproducible without APS dataset license) ─────────────
# Both patterns needed: trailing slash matches real dirs, no slash matches symlinks
closed-corpus-eval/data/processed/
closed-corpus-eval/data/processed

# ── Regenerable intermediate outputs ─────────────────────────────────────────
# Intermediate figure dirs (run 06_publication_figures.py to regenerate)
closed-corpus-eval/data/outputs/figures/
closed-corpus-eval/data/outputs/figures_lowseed/
# Deprecated / dropped figures
closed-corpus-eval/data/outputs/pub_figures/deprecated/
# Live API cache (1.2 GB+, fully regenerable via 09_live_validation.py)
live-survey-eval/data/cache/

# Track curated live-experiment outputs:
#   live-survey-eval/data/gold-sets/    — manual curation
#   live-survey-eval/data/seeds/        — resolved seed records
#   live-survey-eval/data/outputs/*.json, *.csv — validated results
# The live pub_figures are regenerable so exclude them too:
live-survey-eval/data/outputs/pub_figures/

# ── MATLAB/Julia dependencies (large, installable via package manager) ────────
deps-matlab/

# ── Secrets ──────────────────────────────────────────────────────────────────
.env

# ── LaTeX build artifacts ─────────────────────────────────────────────────────
# Recursive (**) so these are also ignored inside submission subfolders
# (jcdl-submission/, jasist-submission/, tois-submission/, archive/**) — not just drafts/ root.
# Submission-folder PDFs are still tracked (snapshot of what was actually submitted);
# only the root-level litdiscover.pdf is excluded, per the Manuscripts section above.
drafts/**/*.aux
drafts/**/*.log
drafts/**/*.bbl
drafts/**/*.blg
drafts/**/*.out
drafts/**/*.fls
drafts/**/*.fdb_latexmk
drafts/**/*.synctex.gz
drafts/**/*.toc
drafts/**/*.spl
